# Database
DATABASE_URL=postgres://psp:psp@localhost:5432/psp?sslmode=disable

# Server
SERVER_ADDR=:8080
MIGRATIONS_DIR=./migrations

# Provider selection: "stripe" or "mock"
ACTIVE_PROVIDER=mock

# Stripe (required when ACTIVE_PROVIDER=stripe)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Mock provider webhook HMAC secret
MOCK_WEBHOOK_SECRET=dev-mock-secret
